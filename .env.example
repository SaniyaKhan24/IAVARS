# ─── Copy this file to .env and fill in your values ──────────────────────────
# Never commit .env to version control.

# Required — OpenAI API key (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-replace-me

# Optional — override the default LLM model
# LLM_MODEL=gpt-4o-mini

# Optional — LLM sampling temperature (0 = deterministic, 1 = creative)
# LLM_TEMPERATURE=0

# Optional — maximum reasoning iterations the agent is allowed to take
# MAX_AGENT_ITERATIONS=15
